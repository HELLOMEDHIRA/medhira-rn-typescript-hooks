{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./lib/typescript",
    "moduleResolution": "bundler"
  },
  "include": ["src"],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx","example","lib"]
}